# 텔레그램 봇 토큰 (BotFather에서 발급)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Gemini API 키 (Google AI Studio에서 발급)
GEMINI_API_KEY=your_gemini_api_key_here

# 텔레그램 채팅 ID (메시지를 받을 사용자/그룹 ID)
CHAT_ID=123456789

# Gemini 모델 (선택, 기본값 사용 가능)
# gemma-4-26b-a4b-it: 사용자가 요청한 gemma4 26b it 모델 (a4b 접미사 포함)
GEMINI_MODEL_PRIMARY=gemma-4-26b-a4b-it
GEMINI_MODEL_SECONDARY=gemini-2.5-flash

# 재생목록 URL (선택)
PLAYLIST_URL=https://youtube.com/playlist?list=PLHEvWqh20QZJdZlsooU4gnoe8EAnqt_yF
